            "variable": "$pomXMLSHA",
            "value": "$FetchPomContents.result.sha"
        },
        {
            "action": "assign",
            "name": "AssignPOMXMLContent",
            "variable": "$pomXMLContent",
            "value": "$FetchPomContents.result.content.replaceAll(\"\\n\",\"\")"
        },
        {
            "name": "Function_4",
            "function": "function decodeBase64(encodedContent) {\n  return Buffer.from(encodedContent, 'base64').toString('utf-8');\n}\n\nfunction encodeBase64(content) {\n  return Buffer.from(content, 'utf-8').toString('base64');\n}\n\n// Unlike Maven_Package_Upgrade (which patches a literal <dependency><version>\n// tag matched by groupId:artifactId), this handles a pom.xml <properties>\n// entry directly - the struts.version property drives both struts2-core\n// and struts2-json-plugin in fraud-cve/pom.xml.\nfunction updatePomProperty(jsonData, pomContent) {\n  const changes = jsonData?.recommendations?.changes || [];\n\n  for (const change of changes) {\n    const propName = change.pom_property;\n    const newVersion = change.new_version;\n    if (!propName || !newVersion) continue;\n\n    const propRegex = new RegExp(`(<${propName}>)[^<]*(</${propName}>)`, 'gm');\n    pomContent = pomContent.replace(propRegex, `$1${newVersion}$2`);\n  }\n\n  if (!pomContent.startsWith('<?xml')) {\n    pomContent = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\\n` + pomContent;\n  }\n\n  return pomContent;\n}\n\nconst decodedPom = decodeBase64($pomXMLContent);\nconst updatedPom = updatePomProperty($input_json_data, decodedPom);\n\n$updatedPomFileContent = updatedPom;\n"
        },
        {
            "action": "comment",
            "value": "Decode current pom.xml content, bump the pom_property value, re-encode"
        },
        {
            "action": "system/Common/String/Base64 Encode",
            "name": "Base64Encode_2",
            "inputs": [
                {
                    "name": "str",
                    "value": "$updatedPomFileContent"
                },
                {
                    "name": "encoding",
                    "value": "\"utf-8\""
                }
            ]
        },
        {
            "action": "assign",
            "name": "Assign_1",
            "variable": "$updatedPomFileContent",
            "value": "$Base64Encode_2.result"
        },
        {
            "action": "comment",
            "value": "Create a new branch name with a timestamp"
        },
        {
            "name": "Function_1",
            "function": "function generateBranchName() {\n    const now = new Date();\n    const timestamp = now.toISOString().replace(/[-:TZ.]/g, \"\").slice(0, 14);\n    return `fix-spring4shell-${timestamp}-${Math.floor(Math.random() * 1000) + 1}`;\n};\n\n$head = generateBranchName();\n$newBranchRef = `refs/heads/${$head}`"
        },
        {
            "action": "comment",
            "value": "Create branch reference from the new branch name"
        },
        {
            "action": "system/Github/Git/Create Ref",
            "name": "CreateGitRef",
            "inputs": [
                {
                    "name": "authKey",
                    "value": "$auth"
                },
                {
                    "name": "owner",
                    "value": "$repo_details.owner"
                },
                {
                    "name": "repo",
                    "value": "$repo_details.repo"
                },
                {
                    "name": "Body",
                    "value": "{\n    \"ref\": $newBranchRef,\n    \"sha\": $baseBranchSHA\n}"
                }
            ]
        },
        {
            "action": "comment",
            "value": "Commit the new changes to the new branch"
        },
        {
            "action": "system/Github/Repos/Create Or Update File Contents",
            "name": "CommitUpdatedPomToGit",
            "inputs": [
                {
                    "name": "authKey",
                    "value": "$auth"
                },
                {
                    "name": "owner",
                    "value": "$repo_details.owner"
                },
                {
                    "name": "repo",
                    "value": "$repo_details.repo"
                },
                {
                    "name": "path",
                    "value": "\"pom.xml\""
                },
                {
                    "name": "Body",
                    "value": "{\n    \"sha\": $pomXMLSHA,\n    \"branch\": $head,\n    \"committer\": {\n        \"name\": $repo_details.owner,\n        \"email\": $email,\n        \"date\": $date\n    },\n    \"message\": \"Bump struts.version to remediate CVE-2017-5638 (Struts2 Jakarta Multipart RCE)\",\n    \"content\": $updatedPomFileContent\n}"
                }
            ]
        },
        {
            "action": "comment",
            "value": "Build a tabular pull request description"
        },
        {
            "name": "Function_2",
            "function": "function pad(str, len) {\n  return str.toString().padEnd(len, ' ');\n}\n\nfunction markdownTable(headers, rows) {\n  const colWidths = headers.map((_, i) => {\n    return Math.max(\n      headers[i].length,\n      ...rows.map(row => (row[i]?.toString()?.length || 0))\n    );\n  });\n\n  const formatRow = row =>\n    `| ${row.map((cell, i) => pad(cell, colWidths[i])).join(' | ')} |`;\n\n  const headerLine = formatRow(headers);\n  const separatorLine = `| ${colWidths.map(w => '-'.repeat(w)).join(' | ')} |`;\n  const dataLines = rows.map(formatRow);\n\n  return [headerLine, separatorLine, ...dataLines].join('\\n');\n}\n\nfunction main(json_data) {\n  const headers = [\"Sl No.\", \"pom.xml property\", \"Current Version\", \"Upgrade Version\"];\n  const data = [];\n\n  const changes = json_data?.recommendations?.changes || [];\n\n  changes.forEach((pkg, index) => {\n    data.push([\n      index + 1,\n      pkg.pom_property,\n      pkg.previous_version,\n      pkg.new_version\n    ]);\n  });\n\n  return markdownTable(headers, data);\n}\n\n$pr_body = main($input_json_data)\n"
        },
        {
            "action": "comment",
            "value": "Create pull request for updating the pom.xml file"
        },
        {
            "action": "system/Github/Pulls/Create",
            "name": "CreatePrWithChanges",
            "inputs": [
                {
                    "name": "authKey",
                    "value": "$auth"
                },
                {
                    "name": "owner",
                    "value": "$repo_details.owner"
                },
                {
                    "name": "repo",
                    "value": "$repo_details.repo"
                },
                {
                    "name": "Body",
                    "value": "{\n    \"title\": \"[Security fix] Bump struts.version (CVE-2017-5638)\",\n    \"head\": $head,\n    \"base\": $repo_details.base,\n    \"body\": $pr_body\n}"
                }
            ]
        },
        {
            "action": "assign",
            "name": "GetPRurl",
            "variable": "$url",
            "value": "$CreatePrWithChanges.result.html_url"
        },
        {
            "action": "assign",
            "name": "GetPRNumber",
            "variable": "$pr_number",
            "value": "$CreatePrWithChanges.result.number"
        }

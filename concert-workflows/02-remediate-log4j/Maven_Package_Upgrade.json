        {
            "action": "assign",
            "name": "AssignPOMXMLContent",
            "variable": "$pomXMLContent",
            "value": "$FetchPomContents.result.content.replaceAll(\"\\n\",\"\")"
        },
        {
            "name": "Function_4",
            "function": "function decodeBase64(encodedContent) {\n  return Buffer.from(encodedContent, 'base64').toString('utf-8');\n}\n\nfunction encodeBase64(content) {\n  return Buffer.from(content, 'utf-8').toString('base64');\n}\n\nfunction updatePomVersion(jsonData, pomContent) {\n  const changes = jsonData?.recommendations?.changes || [];\n\n  for (const change of changes) {\n    const pkg = change.target;\n    const newVersion = change.new_version;\n\n    if (!pkg || !newVersion) continue;\n\n    const [groupId, artifactId] = pkg.split(':');\n    if (!groupId || !artifactId) continue;\n\n    // Regex to update <parent> version\n    const parentRegex = new RegExp(\n      `<parent>\\\\s*<groupId>${groupId}</groupId>\\\\s*<artifactId>[^<]+</artifactId>\\\\s*(<version>[^<]*</version>)?`,\n      'gm'\n    );\n    pomContent = pomContent.replace(parentRegex, (match, versionTag) => {\n      if (versionTag) {\n        return match.replace(/<version>[^<]*<\\/version>/, `<version>${newVersion}</version>`);\n      } else {\n        return match + `\\n<version>${newVersion}</version>`;\n      }\n    });\n\n    // Regex to update <dependency> version\n    const depRegex = new RegExp(\n      `<dependency>\\\\s*<groupId>${groupId}</groupId>\\\\s*<artifactId>${artifactId}</artifactId>\\\\s*(<version>[^<]*</version>)?`,\n      'gm'\n    );\n    pomContent = pomContent.replace(depRegex, (match, versionTag) => {\n      if (versionTag) {\n        return match.replace(/<version>[^<]*<\\/version>/, `<version>${newVersion}</version>`);\n      } else {\n        return match + `\\n<version>${newVersion}</version>`;\n      }\n    });\n  }\n\n  // Add XML declaration if missing\n  if (!pomContent.startsWith('<?xml')) {\n    pomContent = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\\n` + pomContent;\n  }\n\n  return pomContent;\n}\n\n\n\nconst decodedPom = decodeBase64($pomXMLContent);\nconst updatedPom = updatePomVersion($input_json_data, decodedPom);\n\n$updatedPomFileContent =  updatedPom;\n\n"
        },
        {
            "action": "comment",
            "value": "Python function to decode current pom.xml file content, update it and encode the updated content"
        },

                    "value": "{\n    \"sha\": $pomXMLSHA,\n    \"branch\": $head,\n    \"committer\": {\n        \"name\": $repo_details.owner,\n        \"email\": $email,\n        \"date\": $date\n    },\n    \"message\": \"This is updated pom.xml\",\n    \"content\": $updatedPomFileContent\n}"
                }
            ]
        },
        {
            "action": "comment",
            "value": "Python function to create a tabular pull request description"
        },
        {
            "name": "Function_2",
            "function": "function pad(str, len) {\n  return str.toString().padEnd(len, ' ');\n}\n\nfunction markdownTable(headers, rows) {\n  const colWidths = headers.map((_, i) => {\n    return Math.max(\n      headers[i].length,\n      ...rows.map(row => (row[i]?.toString()?.length || 0))\n    );\n  });\n\n  const formatRow = row =>\n    `| ${row.map((cell, i) => pad(cell, colWidths[i])).join(' | ')} |`;\n\n  const headerLine = formatRow(headers);\n  const separatorLine = `| ${colWidths.map(w => '-'.repeat(w)).join(' | ')} |`;\n  const dataLines = rows.map(formatRow);\n\n  return [headerLine, separatorLine, ...dataLines].join('\\n');\n}\n\nfunction main(json_data) {\n  const headers = [\"Sl No.\", \"Package Name\", \"Current Version\", \"Upgrade Version\"];\n  const data = [];\n\n  const changes = json_data?.recommendations?.changes || [];\n\n  changes.forEach((pkg, index) => {\n    data.push([\n      index + 1,\n      pkg.target,\n      pkg.previous_version,\n      pkg.new_version\n    ]);\n  });\n\n  return markdownTable(headers, data);\n}\n\n$pr_body = main($input_json_data)\n"
        },

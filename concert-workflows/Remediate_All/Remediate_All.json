        {
            "action": "comment",
            "value": "3/4 - Merge both PRs via the GitHub REST API (no native Concert 'merge PR' block exists)"
        },
        {
            "action": "system/FaaS/Python",
            "name": "merge_prs",
            "inputs": [
                {
                    "name": "code",
                    "value": "`\"\"\"\nScript to merge the two remediation pull requests (log4j CVE fix and SQLi\nfix) opened by the Maven_Package_Upgrade and SQLi_Code_Remediation\nsubflows, via the GitHub REST API directly (Concert has no native\n\"merge PR\" block, confirmed against IBM's published block catalog).\n\nThis uses subprocess.run() to execute curl, never use \"shell=True\" on\nuser-provided input!!\n\nInput parameters (variables injected by workflow):\n- gh_repo_url:   [required, string]  URL to the repository (e.g. https://github.com/kokunas/java-app-cve)\n- gh_api_token:  [required, string]  GitHub token with pull_requests:write on the repo\n- pr_number_1:   [required, number]  First PR number to merge (log4j fix)\n- pr_number_2:   [required, number]  Second PR number to merge (Spring4Shell fix)\n- pr_number_3:   [required, number]  Third PR number to merge (SQLi fix)\n\"\"\"\n\nimport json as jsonlib\nimport re\nfrom subprocess import run, PIPE, DEVNULL\nfrom sys import exit as sys_exit\nfrom time import sleep\n\n\ndef obfuscate(input_str):\n    if not input_str or len(input_str) <= 8:\n        return \"*\" * len(input_str or \"\")\n    return input_str[0:4] + (\"*\" * (len(input_str) - 4))\n\n\ndef decode_utf8(input_bytes):\n    if input_bytes:\n        return input_bytes.decode(\"utf-8\").strip()\n    return \"\"\n\n\nprint(\"Input parameters\")\nprint(\"=\" * 100)\nprint(\"gh_repo_url   :\", gh_repo_url)\nprint(\"gh_api_token  :\", obfuscate(gh_api_token))\nprint(\"pr_number_1   :\", pr_number_1)\nprint(\"pr_number_2   :\", pr_number_2)\nprint(\"pr_number_3   :\", pr_number_3)\nprint(\"=\" * 100)\n\n# Install curl (Python FaaS image is alpine-based, curl is not preinstalled)\ntry:\n    run([\"apk\", \"add\", \"curl\"], check=True, stdout=DEVNULL, stderr=DEVNULL)\n    print(\"curl successfully installed\")\nexcept Exception as e:\n    print(\"ERROR - Could not install curl:\", e)\n    sys_exit(1)\n\nmatch = re.match(r\"https://github\\.com/([^/]+)/([^/]+?)(?:\\.git)?/?$\", gh_repo_url)\nif not match:\n    print(\"ERROR - Could not parse owner/repo out of gh_repo_url:\", gh_repo_url)\n    sys_exit(1)\nowner, repo = match.group(1), match.group(2)\n\nresults = {}\nfor label, pr_number in ((\"log4j\", pr_number_1), (\"spring4shell\", pr_number_2), (\"sqli\", pr_number_3)):\n    merge_url = f\"https://api.github.com/repos/{owner}/{repo}/pulls/{pr_number}/merge\"\n    body = jsonlib.dumps({\"merge_method\": \"squash\"})\n\n    merged = False\n    attempt, max_attempts = 1, 5\n    while attempt <= max_attempts:\n        merge_command = [\n            \"curl\", \"--fail\", \"--silent\", \"--show-error\", \"--request\", \"PUT\",\n            \"--url\", merge_url,\n            \"--header\", f\"Authorization: Bearer {gh_api_token}\",\n            \"--header\", \"Accept: application/vnd.github+json\",\n            \"--header\", \"Content-Type: application/json\",\n            \"--data\", body,\n        ]\n        merge_result = run(merge_command, check=False, stdout=PIPE, stderr=PIPE)\n        if merge_result.returncode == 0:\n            merged = True\n            break\n        # GitHub returns 405 while checks/mergeability are still being computed\n        # right after PR creation - retry with backoff before giving up.\n        print(f\"[{label}] merge attempt {attempt}/{max_attempts} failed, retrying...\")\n        print(\"stderr:\", decode_utf8(merge_result.stderr))\n        attempt += 1\n        sleep(4)\n\n    results[label] = {\"pr_number\": pr_number, \"merged\": merged}\n    if not merged:\n        print(f\"ERROR - Could not merge PR #{pr_number} ({label}) after {max_attempts} attempts\")\n\nif not all(r[\"merged\"] for r in results.values()):\n    print(\"One or more PRs failed to merge:\", results)\n    sys_exit(1)\n\nprint(\"Both PRs merged successfully:\", results)\n`"
                },
                {
                    "name": "encoding",
                    "value": "\"utf-8\""
                },
                {
                    "name": "parameters",
                    "value": "{\n    \"gh_repo_url\": $gh_repo_url,\n    \"gh_api_token\": $gh_api_token,\n    \"pr_number_1\": $Log4jFix.pr_number,\n    \"pr_number_2\": $SpringFix.pr_number,\n    \"pr_number_3\": $SqliFix.pr_number\n}"
                }
            ]
        },

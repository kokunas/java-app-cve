{
    "name": "Trivy_SSH_Host_Scan",
    "platform": "node",
    "blocks": [
        {
            "action": "comment",
            "value": "Rebuilt with native Concert blocks (Common/SSH, Common/String, Common/JSON, Common/HTTP) instead of a custom Python script - see the workflow README for what's still unverified live (the HTTP Request attachments/body combination for the multipart upload)."
        },
        {
            "action": "system/Common/SSH/SSH",
            "name": "InstallTrivy",
            "inputs": [
                {
                    "name": "authKey",
                    "value": "$ssh_auth"
                },
                {
                    "name": "command",
                    "value": "\"command -v trivy >/dev/null 2>&1 || (curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sudo sh -s -- -b /usr/local/bin v0.72.0)\""
                }
            ]
        },
        {
            "action": "system/Common/SSH/SSH",
            "name": "RunScan",
            "inputs": [
                {
                    "name": "authKey",
                    "value": "$ssh_auth"
                },
                {
                    "name": "command",
                    "value": "\"for i in 1 2 3 4 5; do\\n  sudo trivy rootfs --scanners vuln --format cyclonedx --quiet --output /tmp/trivy-scan.json / && break\\n  sleep 3\\ndone\\ncat /tmp/trivy-scan.json\\nsudo rm -f /tmp/trivy-scan.json\""
                }
            ]
        },
        {
            "action": "system/Common/String/String Replace",
            "name": "PatchSpecVersion",
            "inputs": [
                {
                    "name": "str1",
                    "value": "$RunScan.result"
                },
                {
                    "name": "str2",
                    "value": "\"\\\"specVersion\\\"\\\\s*:\\\\s*\\\"[^\\\"]*\\\"\""
                },
                {
                    "name": "str3",
                    "value": "\"\\\"specVersion\\\":\\\"1.5\\\"\""
                }
            ]
        },
        {
            "action": "assign",
            "name": "BuildMetadataObject",
            "variable": "$metadata_obj",
            "value": "{\n    \"scanner_name\": \"trivy\",\n    \"application_name\": $application_name,\n    \"application_version\": $application_version,\n    \"target\": $target_label\n}"
        },
        {
            "action": "system/Common/JSON/JSON Stringify",
            "name": "StringifyMetadata",
            "inputs": [
                {
                    "name": "object",
                    "value": "$metadata_obj"
                }
            ]
        },
        {
            "action": "system/Common/String/String Append",
            "name": "BuildAuthHeader",
            "inputs": [
                {
                    "name": "str1",
                    "value": "\"C_API_KEY \""
                },
                {
                    "name": "str2",
                    "value": "$concert_api_key"
                }
            ]
        },
        {
            "action": "system/Common/HTTP/HTTP Request",
            "name": "UploadToConcert",
            "inputs": [
                {
                    "name": "method",
                    "value": "\"POST\""
                },
                {
                    "name": "host",
                    "value": "$concert_url"
                },
                {
                    "name": "path",
                    "value": "\"/ingestion/api/v1/upload_files\""
                },
                {
                    "name": "headers",
                    "value": "{\n    \"Authorization\": $BuildAuthHeader.result,\n    \"InstanceId\": $concert_instance_id,\n    \"Content-Type\": \"multipart/form-data\"\n}"
                },
                {
                    "name": "body",
                    "value": "{\n    \"data_type\": \"code_scan\",\n    \"metadata\": $StringifyMetadata.result\n}"
                },
                {
                    "name": "attachments",
                    "value": "[{\n    \"key\": \"filename\",\n    \"content\": $PatchSpecVersion.result,\n    \"filename\": \"ssh-host-scan.json\",\n    \"encoding\": \"utf-8\"\n}]"
                }
            ]
        },
        {
            "action": "assign",
            "name": "copy_scan_result",
            "variable": "$result",
            "value": "$UploadToConcert.result"
        }
    ],
    "variables": [
        {
            "name": "result",
            "required": false,
            "isInput": false,
            "isOutput": true,
            "level": "INTERMEDIATE",
            "type": {
                "type": "any"
            },
            "value": "\"\""
        },
        {
            "name": "ssh_auth",
            "required": true,
            "isInput": true,
            "isOutput": false,
            "level": "INTERMEDIATE",
            "type": {
                "type": "any"
            },
            "value": "\"concert-cve-ssh-key\"",
            "meta": {
                "authType": "Common/SSH",
                "description": "Name of a Common/SSH credential stored in Concert (Administration -> Credentials -> Add -> Common/SSH) holding the target host/port/username/private key. Create it once, reference it here by name - the raw key is never pasted into this workflow's trigger payload."
            }
        },
        {
            "name": "concert_url",
            "required": true,
            "isInput": true,
            "isOutput": false,
            "level": "INTERMEDIATE",
            "type": {
                "type": "string"
            },
            "value": "\"https://concert-concert.apps.itz-4j78fp.pok-lb.techzone.ibm.com\""
        },
        {
            "name": "concert_api_key",
            "required": true,
            "isInput": true,
            "isOutput": false,
            "level": "INTERMEDIATE",
            "type": {
                "type": "string"
            },
            "value": "\"\"",
            "meta": {
                "notLogged": true,
                "subType": "password"
            }
        },
        {
            "name": "concert_instance_id",
            "required": true,
            "isInput": true,
            "isOutput": false,
            "level": "INTERMEDIATE",
            "type": {
                "type": "string"
            },
            "value": "\"0000-0000-0000-0000\""
        },
        {
            "name": "application_name",
            "required": false,
            "isInput": true,
            "isOutput": false,
            "level": "INTERMEDIATE",
            "type": {
                "type": "string"
            },
            "value": "\"amazon-linux-demo\""
        },
        {
            "name": "application_version",
            "required": false,
            "isInput": true,
            "isOutput": false,
            "level": "INTERMEDIATE",
            "type": {
                "type": "string"
            },
            "value": "\"1.0.0\""
        },
        {
            "name": "target_label",
            "required": false,
            "isInput": true,
            "isOutput": false,
            "level": "INTERMEDIATE",
            "type": {
                "type": "string"
            },
            "value": "\"\"",
            "meta": {
                "description": "Free-text label for the scanned host, only used in the Concert ingestion metadata (e.g. \"ec2-user@52.59.245.141\")"
            }
        }
    ],
    "meta": {
        "workerGroup": "default",
        "description": "Scans a remote Linux host over SSH for OS-level vulnerabilities using Trivy, built entirely from native Concert blocks (Common/SSH, Common/String, Common/JSON, Common/HTTP) instead of a custom FaaS/Python script - the SSH key lives in a stored Concert credential, never in this workflow's own inputs.",
        "layout": "flow",
        "numberOfBlocks": 9,
        "version": 5,
        "tags": [
            {
                "name": "Consumer",
                "value": "Concert"
            },
            {
                "name": "Category",
                "value": "Vulnerability"
            }
        ]
    },
    "finally": null
}

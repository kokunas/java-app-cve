{
    "name": "Trivy_SSH_Host_Scan",
    "platform": "node",
    "blocks": [
        {
            "action": "comment",
            "value": "Rebuilt with native Concert blocks matching IBM's own published patterns (RHEL_SCAN_OSCAP_GRYPE, Apply_Amazon_Linux_Patch): Common/SSH for remote commands, a plain JS function block for the specVersion patch + metadata (no FaaS/Python sandbox), and the official system/IBM/Concert v2/Import Data/Upload Files to Concert block (data_type=vm_scan) instead of a raw HTTP call."
        },
        {
            "action": "system/Common/SSH/SSH",
            "name": "InstallTrivy",
            "inputs": [
                {
                    "name": "authKey",
                    "value": "$ssh_auth"
                },
                {
                    "name": "command",
                    "value": "\"command -v trivy >/dev/null 2>&1 || (curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sudo sh -s -- -b /usr/local/bin v0.72.0)\"",
                    "type": "const"
                }
            ]
        },
        {
            "action": "system/Common/SSH/SSH",
            "name": "RunScan",
            "inputs": [
                {
                    "name": "authKey",
                    "value": "$ssh_auth"
                },
                {
                    "name": "command",
                    "value": "\"for i in 1 2 3 4 5; do\\n  sudo trivy rootfs --scanners vuln --format cyclonedx --quiet --output /tmp/trivy-scan.json / && break\\n  sleep 3\\ndone\\ncat /tmp/trivy-scan.json\\nsudo rm -f /tmp/trivy-scan.json\"",
                    "type": "const"
                }
            ]
        },
        {
            "name": "BuildPayload",
            "function": "$patched_scan = $RunScan.result.replace(/\"specVersion\"\\s*:\\s*\"[^\"]*\"/, '\"specVersion\":\"1.5\"');\n$metadata_str = JSON.stringify({\n    scanner_name: \"trivy\",\n    application_name: $application_name,\n    application_version: $application_version,\n    target: $target_label\n});"
        },
        {
            "action": "system/IBM/Concert v2/Import Data/Upload Files to Concert",
            "name": "IngestScan",
            "inputs": [
                {
                    "name": "authKey",
                    "value": "$concert_auth"
                },
                {
                    "name": "file",
                    "value": "{\n    \"data_type\": \"vm_scan\",\n    \"metadata\": $metadata_str,\n    \"filename\": [$patched_scan]\n}"
                },
                {
                    "name": "fileType",
                    "value": "\"json\""
                }
            ]
        },
        {
            "action": "assign",
            "name": "copy_scan_result",
            "variable": "$result",
            "value": "$IngestScan.result"
        }
    ],
    "variables": [
        {
            "name": "result",
            "required": false,
            "isInput": false,
            "isOutput": true,
            "level": "INTERMEDIATE",
            "type": {
                "type": "any"
            },
            "value": "\"\""
        },
        {
            "name": "ssh_auth",
            "required": true,
            "isInput": true,
            "isOutput": false,
            "level": "INTERMEDIATE",
            "type": {
                "type": "any"
            },
            "value": "\"\"",
            "meta": {
                "authType": "ANY",
                "subType": "authentication",
                "description": "Common/SSH credential stored in Concert (Administration -> Credentials) for the target host - host/port/username/private key never appear in this workflow's own inputs."
            }
        },
        {
            "name": "concert_auth",
            "required": true,
            "isInput": true,
            "isOutput": false,
            "level": "INTERMEDIATE",
            "type": {
                "type": "any"
            },
            "value": "\"\"",
            "meta": {
                "authType": "ANY",
                "subType": "authentication",
                "description": "Stored Concert API credential (url/api key/instance id), same one used by other IBM-published workflows' Import Data / Action Insights blocks."
            }
        },
        {
            "name": "application_name",
            "required": false,
            "isInput": true,
            "isOutput": false,
            "level": "INTERMEDIATE",
            "type": {
                "type": "string"
            },
            "value": "\"amazon-linux-demo\""
        },
        {
            "name": "application_version",
            "required": false,
            "isInput": true,
            "isOutput": false,
            "level": "INTERMEDIATE",
            "type": {
                "type": "string"
            },
            "value": "\"1.0.0\""
        },
        {
            "name": "target_label",
            "required": false,
            "isInput": true,
            "isOutput": false,
            "level": "INTERMEDIATE",
            "type": {
                "type": "string"
            },
            "value": "\"\"",
            "meta": {
                "description": "Free-text label for the scanned host, only used in the ingestion metadata (e.g. \"ec2-user@52.59.245.141\")"
            }
        },
        {
            "name": "patched_scan",
            "required": false,
            "isInput": false,
            "isOutput": false,
            "level": "INTERMEDIATE",
            "type": {
                "type": "string"
            },
            "value": "\"\""
        },
        {
            "name": "metadata_str",
            "required": false,
            "isInput": false,
            "isOutput": false,
            "level": "INTERMEDIATE",
            "type": {
                "type": "string"
            },
            "value": "\"\""
        }
    ],
    "meta": {
        "workerGroup": "default",
        "description": "Scans a remote Linux host over SSH for OS-level vulnerabilities using Trivy, built from native Concert blocks matching IBM's own published workflow patterns (Common/SSH, a JS function block, and the official Import Data / Upload Files to Concert ingestion block with data_type=vm_scan).",
        "layout": "flow",
        "numberOfBlocks": 6,
        "version": 5,
        "tags": [
            {
                "name": "Consumer",
                "value": "Concert"
            },
            {
                "name": "Category",
                "value": "Vulnerability"
            }
        ]
    },
    "finally": null
}
